            print(f"  {name}: {value:.3f}")
        else:
            print(f"  {name}: {value}")

if hasattr(results, "tables") and results.tables:
    for table_name, table_df in results.tables.items():
        # Drop complex nested columns for display
        skip_cols = {"assessments", "spans", "trace", "trace_metadata", "tags"}
        display_cols = [c for c in table_df.columns if c not in skip_cols]
        print(f"\n{table_name}:")
        display(table_df[display_cols])

# COMMAND ----------

# DBTITLE 1,Quality Gate
print("=" * 80)
print(f"QUALITY GATE — {eval_threshold_mode.upper()} thresholds")
print("=" * 80)

if not hasattr(results, "metrics") or not results.metrics:
    print("WARNING: No metrics returned from evaluation. Skipping quality gate.")
    dbutils.notebook.exit("EVALUATION_NO_METRICS")

passed, failures = thresholds.check(results.metrics)

if passed:
    print("PASSED — all metrics meet thresholds")
    for key, min_score in thresholds.thresholds.items():
        matched = [
            (n, v) for n, v in results.metrics.items()
            if key.lower() in n.lower() and isinstance(v, (int, float))
        ]
        for name, value in matched:
            print(f"  {name}: {value:.3f} >= {min_score:.3f}")
    dbutils.notebook.exit("EVALUATION_PASSED")
else:
    print("FAILED — the following metrics are below threshold:")
    for f in failures:
        print(f"  {f}")
    print()
    print("To adjust thresholds, set eval_threshold_mode in databricks.yml")
    print("or override individual thresholds in this notebook.")
    # Exit with failure message — this causes the job task to fail
    dbutils.notebook.exit("EVALUATION_FAILED")
