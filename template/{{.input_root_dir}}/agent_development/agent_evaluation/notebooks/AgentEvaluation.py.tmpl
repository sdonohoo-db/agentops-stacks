# DBTITLE 1,Build Predict Function
import asyncio
from mlflow.types.responses import ResponsesAgentRequest

# Wrap the invoke function for mlflow.genai.evaluate().
# The predict_fn signature must match the keys in the evaluation data's 'inputs' dict.
if asyncio.iscoroutinefunction(invoke_fn):
    import nest_asyncio
    nest_asyncio.apply()

    def predict_fn(input: list[dict], **kwargs) -> dict:
        req = ResponsesAgentRequest(input=input)
        loop = asyncio.get_event_loop()
        response = loop.run_until_complete(invoke_fn(req))
        return response.model_dump()
else:
    def predict_fn(input: list[dict], **kwargs) -> dict:
        req = ResponsesAgentRequest(input=input)
        response = invoke_fn(req)
        return response.model_dump()

# Quick smoke test
test_response = predict_fn(input=[{"role": "user", "content": "Hello"}])
print(f"Smoke test passed — response has {len(test_response.get('output', []))} output items")

# COMMAND ----------

# DBTITLE 1,Load Evaluation Data
# Two evaluation modes:
# 1. ConversationSimulator — multi-turn tests with simulated users (default)
# 2. Reference dataset — single-turn Q&A from a UC table (if eval_table exists)

from mlflow.genai.scorers import (
    Correctness,
    RelevanceToQuery,
    Safety,
    Fluency,
    Guidelines,
)

# Check if a reference eval table exists in Unity Catalog
eval_data = None
use_simulator = True
scorers = []

if eval_table:
    try:
        table_name = f"{uc_catalog}.{schema}.{eval_table}"
        eval_df = spark.read.table(table_name).toPandas()
        if len(eval_df) > 0:
            # Transform to MLflow GenAI format
            eval_data = []
            for _, row in eval_df.iterrows():
                record = {
                    "inputs": {
                        "input": [{"role": "user", "content": str(row.get("request", row.get("question", "")))}]
                    },
                }
                expected = row.get("expected_response", row.get("expected_answer", ""))
                if expected:
                    record["expectations"] = {"expected_response": str(expected)}
                eval_data.append(record)

            use_simulator = False
            print(f"Loaded {len(eval_data)} records from {table_name}")
    except Exception as e:
        print(f"No eval table found ({e}), falling back to ConversationSimulator")

if use_simulator:
    from mlflow.genai.simulators import ConversationSimulator

    test_cases = [
        {
            "goal": "Get a clear, accurate answer to a straightforward question",
            "persona": "A technical user who asks direct questions and expects concise answers.",
            "simulation_guidelines": [
                "Ask 2-3 follow-up questions to test depth of knowledge.",
            ],
        },
        {
            "goal": "Understand a complex topic through conversation",
            "persona": "A non-technical user who needs concepts explained simply.",
            "simulation_guidelines": [
                "Start broad, then ask for specifics.",
                "If the answer is unclear, ask for clarification.",
            ],
        },
    ]

    eval_data = ConversationSimulator(
        test_cases=test_cases,
        max_turns=4,
        user_model="databricks:/databricks-claude-sonnet-4-5",
    )
    print("Using ConversationSimulator for evaluation")

# COMMAND ----------

# DBTITLE 1,Configure Scorers
from mlflow.genai.scorers import (
    Correctness,
    RelevanceToQuery,
    Safety,
    Fluency,
    Guidelines,
)

if use_simulator:
    # Conversational scorers — test multi-turn behavior
    from mlflow.genai.scorers import (
        Completeness,
        ConversationalSafety,
        ConversationCompleteness,
        KnowledgeRetention,
        ToolCallCorrectness,
        UserFrustration,
    )
    scorers = [
        RelevanceToQuery(),
        Safety(),
        Fluency(),
        Completeness(),
        ConversationCompleteness(),
        ConversationalSafety(),
        KnowledgeRetention(),
        ToolCallCorrectness(),
        UserFrustration(),
    ]
else:
    # Reference dataset scorers — test factual correctness
    scorers = [
        Correctness(),
        RelevanceToQuery(),
        Safety(),
        Fluency(),
        Guidelines(
            name="groundedness",
            guidelines=(
                "The response must be grounded in verifiable facts. "
                "It should not fabricate information or hallucinate details "
                "not supported by the context or question."
            ),
        ),
    ]

print(f"Configured {len(scorers)} scorers")

# COMMAND ----------

# DBTITLE 1,Run Evaluation
import mlflow
import warnings

warnings.filterwarnings("ignore", message=".*notebook authentication token.*")

mlflow.set_experiment(experiment)

print("Starting evaluation...")
print(f"Scorers: {[type(s).__name__ if hasattr(s, '__class__') else s.__name__ for s in scorers]}")

results = mlflow.genai.evaluate(
    data=eval_data,
    predict_fn=predict_fn,
    scorers=scorers,
)

