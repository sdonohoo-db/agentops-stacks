# DBTITLE 1,Define Evaluation Scorers (MLflow 3.9 GenAI)
# MLflow 3.9 GenAI uses mlflow.genai.scorers for LLM-as-a-judge and custom scorers.
# See https://mlflow.org/docs/3.9.0/genai/eval-monitor/quickstart.md

from mlflow.genai import scorer
from mlflow.genai.scorers import Correctness, Guidelines

# Correctness: uses "expected_response" from expectations to score factual correctness
# Guidelines: custom guideline for response quality (e.g. English, professional)
@scorer
def response_quality(outputs: str) -> bool:
    """Evaluate if the response is concise and does not expose internal tool names."""
    if not outputs or not isinstance(outputs, str):
        return False
    # Prefer responses that don't mention internal functions
    internal_markers = ["get_table_info()", "get_", "tool_call", "function call"]
    return not any(m in outputs for m in internal_markers)

scorers = [
    Correctness(),  # Compares output to expectations["expected_response"]
    Guidelines(
        name="is_professional",
        guidelines="The answer must be clear, professional, and in English. Avoid mentioning internal tools or functions.",
    ),
    response_quality,
]
print(f"Loaded {len(scorers)} evaluation scorers (MLflow 3.9 GenAI)")

# COMMAND ----------

# DBTITLE 1,Run Evaluation (MLflow 3.9 GenAI)
# MLflow 3.9 GenAI: mlflow.genai.evaluate(data, predict_fn, scorers)
# https://mlflow.org/docs/3.9.0/genai/eval-monitor/quickstart.md

import os
import warnings

os.environ["DATABRICKS_VECTOR_SEARCH_DISABLE_NOTICE"] = "1"
warnings.filterwarnings('ignore', message='.*notebook authentication token.*')

mlflow.set_experiment(experiment)

print("Starting evaluation run (MLflow 3.9 GenAI)...")
print(f"Dataset size: {len(evaluation_records)} records")
print(f"Model: {model_uri}")
print(f"Number of scorers: {len(scorers)}")

# predict_fn must accept the same keyword as in inputs (here: question)
def qa_predict_fn(question: str) -> str:
    """Wrapper for mlflow.genai.evaluate; key must match inputs['question']."""
    return predict_wrapper(question)

results = mlflow.genai.evaluate(
    data=evaluation_records,
    predict_fn=qa_predict_fn,
    scorers=scorers,
)

print("\nEvaluation complete!")
if hasattr(results, "metrics"):
    print(f"Metrics: {results.metrics}")
if hasattr(results, "tables") and results.tables:
    for name, tbl in results.tables.items():
        print(f"Table: {name}")

