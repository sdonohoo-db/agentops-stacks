# DBTITLE 1,Get Reference Documentation and Prepare for Dataset
import pandas as pd
from pyspark.sql import SparkSession

# Initialize Spark session if not already available
try:
    spark
except NameError:
    spark = SparkSession.builder.getOrCreate()

# Download the reference documentation from Databricks demos
print("Loading reference documentation from Databricks demos...")
ref_docs_df = pd.read_parquet(
    'https://notebooks.databricks.com/demos/dbdemos-dataset/llm/databricks-documentation/databricks_doc_eval_set.parquet'
)

print(f"Loaded {len(ref_docs_df)} reference documents")
display(ref_docs_df.head())

# COMMAND ----------

# DBTITLE 1,Transform Data to MLflow 3.9 GenAI Evaluation Dataset Format
# MLflow 3.9 GenAI expects each record to have 'inputs' and 'expectations'.
# 'inputs' keys must match the parameter name of the predict_fn (e.g. question).
# 'expectations' can include 'expected_response' for the Correctness scorer.
# See https://mlflow.org/docs/3.9.0/genai/eval-monitor/quickstart.md

evaluation_records = []
for idx, row in ref_docs_df.head(100).iterrows():
    record = {
        "inputs": {
            "question": row.get('request', '')
        },
        "expectations": {
            "expected_response": row.get('expected_response', '')
        }
    }
    evaluation_records.append(record)

print(f"Transformed {len(evaluation_records)} records for evaluation dataset")
print("\nSample record structure:")
print(evaluation_records[0])

# COMMAND ----------

# DBTITLE 1,Optionally Persist Evaluation Dataset (MLflow 3.9 GenAI)
# In MLflow 3.9, datasets can be created and associated with an experiment for reuse.
# For evaluate() we use the in-memory list above; optionally persist to UC table.
import mlflow

dataset_name = f"{uc_catalog}.{schema}.{eval_table}"
try:
    from mlflow.genai.datasets import get_dataset, create_dataset
    eval_dataset = get_dataset(name=dataset_name)
    print(f"Using existing dataset: {dataset_name}")
except Exception as e:
    if "does not exist" in str(e).lower() or "NotFound" in str(type(e).__name__):
        eval_dataset = create_dataset(name=dataset_name)
        if hasattr(eval_dataset, "merge_records"):
            eval_dataset.merge_records(evaluation_records)
        print("Created dataset and added records.")
    else:
        raise

