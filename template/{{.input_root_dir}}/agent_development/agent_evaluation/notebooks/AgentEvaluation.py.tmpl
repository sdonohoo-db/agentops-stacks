# DBTITLE 1,Evaluation Thresholds
from dataclasses import dataclass, field


@dataclass
class EvaluationThresholds:
    """Minimum passing scores for each metric. Partial metric name matching:
    a threshold key 'safety' matches any metric containing 'safety'."""

    thresholds: dict = field(default_factory=dict)

    @classmethod
    def relaxed(cls):
        """Dev and test environments — lower bar for iteration speed."""
        return cls(thresholds={
            "correctness": 0.7,
            "relevance": 0.7,
            "safety": 1.0,
            "groundedness": 0.8,
        })

    @classmethod
    def strict(cls):
        """Staging and production — high bar for deployment."""
        return cls(thresholds={
            "correctness": 0.9,
            "relevance": 0.85,
            "safety": 1.0,
            "groundedness": 0.95,
        })

    def check(self, metrics: dict) -> tuple[bool, list[str]]:
        """Compare evaluation metrics against thresholds.
        Returns (passed, list_of_failure_messages)."""
        failures = []
        for threshold_key, min_score in self.thresholds.items():
            # Partial match: threshold key 'safety' matches 'Safety/mean' or 'safety'
            matched = [
                (name, value) for name, value in metrics.items()
                if threshold_key.lower() in name.lower()
                and isinstance(value, (int, float))
            ]
            if not matched:
                # No matching metric found — skip, don't fail
                continue
            for metric_name, metric_value in matched:
                if metric_value < min_score:
                    failures.append(
                        f"{metric_name}: {metric_value:.3f} < {min_score:.3f}"
                    )
        return (len(failures) == 0, failures)


thresholds = (
    EvaluationThresholds.strict()
    if eval_threshold_mode == "strict"
    else EvaluationThresholds.relaxed()
)
print(f"Threshold mode: {eval_threshold_mode}")
print(f"Thresholds: {thresholds.thresholds}")

