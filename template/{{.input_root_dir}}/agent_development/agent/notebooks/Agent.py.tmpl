# DBTITLE 1,Agent Development - Log and Register
##################################################################################
# Agent Development
#
# Imports the agent from agent_server/ (installed by 'uv run setup'), tests it,
# logs it to MLflow, and registers it in Unity Catalog. The agent code itself
# lives in agent_server/agent.py — this notebook handles the MLflow model
# lifecycle, not the agent logic.
#
# Parameters:
# * uc_catalog (required)       - Unity Catalog catalog name
# * schema (required)           - Schema name inside Unity Catalog
# * experiment (required)       - MLflow experiment path
# * registered_model (required) - Model name to register in Unity Catalog
# * model_alias (required)      - Alias for the registered model version
# * git_source_info (optional)  - Git provenance injected by the bundle
##################################################################################

# COMMAND ----------

# DBTITLE 1,Install Dependencies
# Install from the project's pyproject.toml so all framework-specific deps are included
%pip install -e ../../../ --quiet
dbutils.library.restartPython()

# COMMAND ----------

# DBTITLE 1,Widget Setup
dbutils.widgets.text("uc_catalog", "", label="Unity Catalog")
dbutils.widgets.text("schema", "", label="Schema")
dbutils.widgets.text("experiment", "", label="Experiment path")
dbutils.widgets.text("registered_model", "", label="Registered model name")
dbutils.widgets.text("model_alias", "agent_latest", label="Model alias")
dbutils.widgets.text("git_source_info", "", label="Git source info")

# COMMAND ----------

# DBTITLE 1,Read Parameters
uc_catalog = dbutils.widgets.get("uc_catalog")
schema = dbutils.widgets.get("schema")
experiment = dbutils.widgets.get("experiment")
registered_model = dbutils.widgets.get("registered_model")
model_alias = dbutils.widgets.get("model_alias")
git_source_info = dbutils.widgets.get("git_source_info")

assert uc_catalog, "uc_catalog must be specified"
assert schema, "schema must be specified"
assert experiment, "experiment must be specified"
assert registered_model, "registered_model must be specified"
assert model_alias, "model_alias must be specified"

# COMMAND ----------

# DBTITLE 1,Import Agent and Get Invoke Function
import sys
import os

# The bundle syncs agent_server/ to the workspace root alongside this notebook's
# parent directories. Add the project root so agent_server is importable.
project_root = os.path.abspath(os.path.join(os.getcwd(), "../../.."))
if project_root not in sys.path:
    sys.path.insert(0, project_root)

# Importing the agent module registers the @invoke/@stream handlers
import agent_server.agent  # noqa: F401

from mlflow.genai.agent_server import get_invoke_function

invoke_fn = get_invoke_function()
assert invoke_fn is not None, (
    "No @invoke handler found. Make sure agent_server/agent.py defines a function "
    "decorated with @invoke(). Run 'uv run setup' if you haven't installed an agent framework."
)

print(f"Agent loaded: {invoke_fn.__name__}")

# COMMAND ----------

# DBTITLE 1,Test Agent
import asyncio
from mlflow.types.responses import ResponsesAgentRequest

test_request = ResponsesAgentRequest(
    input=[{"role": "user", "content": "What is Databricks?"}]
)

if asyncio.iscoroutinefunction(invoke_fn):
    import nest_asyncio
    nest_asyncio.apply()
    loop = asyncio.get_event_loop()
    test_response = loop.run_until_complete(invoke_fn(test_request))
else:
    test_response = invoke_fn(test_request)

print("Agent response:")
response_dict = test_response.model_dump()
for item in response_dict.get("output", []):
    if item.get("type") == "message" and item.get("role") == "assistant":
        content = item.get("content", [])
        if isinstance(content, list):
            for c in content:
                if isinstance(c, dict) and c.get("type") == "text":
                    print(c["text"][:500])
        elif isinstance(content, str):
            print(content[:500])

# COMMAND ----------

# DBTITLE 1,Log Agent to MLflow
import mlflow

mlflow.set_experiment(experiment)

# Log the agent as a code-based model. The agent_server directory contains
# the actual agent logic; we log it as an artifact so it's captured in the run.
with mlflow.start_run() as run:
    if git_source_info:
        mlflow.log_param("git_source_info", git_source_info)

    model_info = mlflow.pyfunc.log_model(
        python_model="agent_server/agent.py",
        name="agent",
        code_paths=["agent_server"],
        input_example={"input": [{"role": "user", "content": "What is Databricks?"}]},
    )

print(f"MLflow run: {run.info.run_id}")
print(f"Model URI: {model_info.model_uri}")

# COMMAND ----------

# DBTITLE 1,Register in Unity Catalog
registered_model_name = f"{uc_catalog}.{schema}.{registered_model}"

uc_model_info = mlflow.register_model(
    model_info.model_uri,
    name=registered_model_name,
)

# Set alias for downstream evaluation and tracking
client = mlflow.MlflowClient()
client.set_registered_model_alias(
    registered_model_name,
    model_alias,
    uc_model_info.version,
)

print(f"Registered: {registered_model_name}")
print(f"Version: {uc_model_info.version}")
print(f"Alias: {model_alias}")

# COMMAND ----------

# DBTITLE 1,Done
dbutils.notebook.exit(f"Model registered: {registered_model_name} v{uc_model_info.version}")
