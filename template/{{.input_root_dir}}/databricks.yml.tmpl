bundle:
  name: {{ .input_project_name }}

variables:
  app_name:
    description: "Databricks App name (lowercase, numbers, dashes only)."
    default: "{{- (regexp `_`).ReplaceAllString .input_project_name `-` -}}"

resources:
  experiments:
    {{template `project_name_alphanumeric_underscore` .}}_experiment:
      name: /Users/${workspace.current_user.userName}/{{ .input_project_name }}

include:
  - ./resources/app-resource.yml

# Sync agent server and app files to workspace
sync:
  include:
    - agent_server/**
    - scripts/**
    - app.yaml
    - pyproject.toml
    - .env.example

targets:
  dev:
    default: true
    mode: development
    workspace:
      host: # TODO: set your dev workspace URL

  staging:
    workspace:
      host: # TODO: set your staging workspace URL

  prod:
    mode: production
    workspace:
      host: # TODO: set your prod workspace URL

  test:
    workspace:
      host: # TODO: set your test workspace URL (often same as staging)
