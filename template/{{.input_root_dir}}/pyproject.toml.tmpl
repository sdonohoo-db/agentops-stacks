[project]
name = "{{ .input_project_name }}"
version = "0.1.0"
description = "AgentOps agent project"
requires-python = ">=3.11"
dependencies = [
    "fastapi>=0.129.0",
    "uvicorn>=0.41.0",
    "mlflow>=3.10.0",
    "databricks-agents>=1.9.3",
    "python-dotenv>=1.2.1",
]

[tool.uv]
prerelease = "allow"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["agent_server", "scripts"]

[dependency-groups]
dev = [
    "hatchling>=1.28.0",
    "pytest>=9.0.2",
]

[project.scripts]
setup = "scripts.setup:main"
start-server = "agent_server.start_server:main"
start-app = "scripts.start_app:main"
