import os
import dash
import dash_bootstrap_components as dbc
from DatabricksChatbot import DatabricksChatbot
from dotenv import load_dotenv

load_dotenv()

# SERVING_ENDPOINT is set from bundle variable agent_serving_endpoint (config.env in app-resource.yml)
serving_endpoint = os.getenv('SERVING_ENDPOINT')
if not serving_endpoint:
    raise SystemExit(
        'SERVING_ENDPOINT is not set. Set agent_serving_endpoint in your bundle target (databricks.yml or --var), '
        'then redeploy. Run the model serving notebook first to create the endpoint.'
    )

# Initialize the Dash app with a clean theme
app = dash.Dash(__name__, external_stylesheets=[dbc.themes.FLATLY])

# Create the chatbot component with a specified height
chatbot = DatabricksChatbot(app=app, endpoint_name=serving_endpoint, height='600px')

# Define the app layout
app.layout = dbc.Container([
    dbc.Row([
        dbc.Col(chatbot.layout, width={'size': 8, 'offset': 2})
    ])
], fluid=True)

if __name__ == '__main__':
    app.run_server(debug=True)