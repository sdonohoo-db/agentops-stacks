# DBTITLE 1,Grant App Permission to Query Endpoint

from databricks.sdk import WorkspaceClient

w = WorkspaceClient()

# Find the app service principal by searching for the app name
# The app name follows the pattern: {target}-{app_name}. App names must use only lowercase letters, numbers, and dashes.
# We need to grant the app's service principal permission to query the endpoint
try:
    apps = list(w.apps.list())

    # Search for apps that might match this bundle's app
    # App name is defined in databricks.yml 
    matching_apps = [app for app in apps if app.name and '{{template `project_name_alphanumeric_underscore` .}}' in app.name and 'chatbot' in app.name]

    if matching_apps:
        for app in matching_apps:
            if app.service_principal_client_id:
                print(f"Granting permission to app '{app.name}' (service principal: {app.service_principal_client_id})")

                # Get current permissions
                current_perms = w.serving_endpoints.get_permissions(serving_endpoint_id=endpoint_name)

                # Build new access control list preserving existing permissions
                acl = []
                if current_perms.access_control_list:
                    acl = [
                        {
                            "user_name": perm.user_name,
                            "group_name": perm.group_name,
                            "service_principal_name": perm.service_principal_name,
                            "permission_level": perm.all_permissions[0].permission_level
                        }
                        for perm in current_perms.access_control_list
                        if perm.service_principal_name != app.service_principal_client_id  # Don't duplicate
                    ]

                # Add app service principal with CAN_QUERY permission
                acl.append({
                    "service_principal_name": app.service_principal_client_id,
                    "permission_level": "CAN_QUERY"
                })

                w.serving_endpoints.set_permissions(
                    serving_endpoint_id=endpoint_name,
                    access_control_list=acl
                )
                print(f"✓ Granted CAN_QUERY permission to app service principal")
    else:
        print("Warning: Could not find matching app to grant permissions. You may need to grant permissions manually.")

except Exception as e:
    print(f"Warning: Could not grant app permissions automatically: {e}")
    print("You may need to grant the app service principal CAN_QUERY permission manually via the UI.")

