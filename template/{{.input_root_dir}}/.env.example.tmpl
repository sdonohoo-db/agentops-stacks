# Local development environment configuration
# Copy to .env and fill in values: cp .env.example .env

# Databricks authentication — use a CLI profile or set host + token
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://<your-workspace-url>
# DATABRICKS_TOKEN=dapi...

# MLflow experiment for tracing
MLFLOW_EXPERIMENT_ID=

# Agent server settings (defaults match app.yaml)
API_PROXY=http://localhost:8000/invocations
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
MLFLOW_TRACKING_URI=databricks
MLFLOW_REGISTRY_URI=databricks-uc
